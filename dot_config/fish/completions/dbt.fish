function __dbt_match_path --description 'True if recognized dbt command-token path equals argv'
    set -l expected $argv
    set -l tokens (commandline -opc)

    if test (count $tokens) -gt 0
        if test "$tokens[1]" = "dbt"
            set -e tokens[1]
        end
    end

    set -l cmd_tokens
    for t in $tokens
        if contains -- $t $__dbt_all_cmd_words
            set cmd_tokens $cmd_tokens $t
        end
    end

    if test (count $cmd_tokens) -ne (count $expected)
        return 1
    end

    set -l n (count $expected)
    if test $n -eq 0
        return 0
    end

    for i in (seq 1 $n)
        if test "$cmd_tokens[$i]" != "$expected[$i]"
            return 1
        end
    end

    return 0
end

