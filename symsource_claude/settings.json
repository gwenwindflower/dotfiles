  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/set-sandbox-tmpdir.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/set-git-nosign.sh"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/inject-commit-reminder.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/require-teammate-commit.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "winline",
    "padding": 0
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "worktrunk@worktrunk": true,
    "ruby-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "backend.blacksmith.sh",
        "clireleases.blacksmith.sh",
        "context7.com",
        "jsr.io",
        "pkg.go.dev",
        "proxy.golang.org",
        "pypi.org",
        "pythonhosted.org",
        "registry.npmjs.org",
        "registry.npmjs.org",
        "storage.googleapis.com",
        "sum.golang.org",
        "telemetry.astro.build"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "~/.local/share/graveyard/**",
        "~/.blacksmith/**",
        "~/.bun/install/cache**",
        "~/.cache/uv/**",
        "~/.local/share/uv/tools/**",
        "~/.config/.wrangler/**",
        "~/.go/pkg/mod/cache/**",
        "~/Library/Caches/go-build/**",
        "~/.local/share/pnpm/**",
        "~/.cache/pnpm/**"
      ]
    }
  },
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Being a pretty pony",
      "Crocheting a cat sweater",
      "Kekeking",
      "Romanticizing everything",
      "Crying to Chappell Roan",
