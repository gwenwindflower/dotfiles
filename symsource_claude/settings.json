      "Read(*.key)",
      "Read(*.p12)",
      "Read(*.pfx)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(*.env)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.gnupg/**)",
