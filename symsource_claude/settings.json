    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(*.env)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.config/gcloud/**)",
      "Read(**/secrets/**)",
