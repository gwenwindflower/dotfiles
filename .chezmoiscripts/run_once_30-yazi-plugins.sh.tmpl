{{ if eq .chezmoi.os "darwin" "linux" -}}
#!/bin/bash
# Install yazi plugins on first apply
# Ongoing updates handled by run_onchange_ on package.toml changes

set -euo pipefail

{{ template "script-log.sh" }}
{{ template "brew-preamble.sh" . }}

log_step "Yazi plugins"

if command -v ya >/dev/null 2>&1; then
  log_info "Installing yazi plugins..."
  ya pkg install
  log_success "Yazi plugins installed"
else
  log_warn "ya not found, skipping yazi plugin install"
fi
{{ else -}}
{{ fail (printf "unsupported OS: %s" .chezmoi.os) }}
{{ end -}}
