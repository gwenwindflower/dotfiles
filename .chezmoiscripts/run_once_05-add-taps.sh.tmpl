{{ if eq .chezmoi.os "darwin" "linux" -}}
{{- $taps := list -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $taps = .packages.darwin.homebrew.taps -}}
{{- else -}}
{{-   $taps = .packages.linux.homebrew.taps -}}
{{- end -}}
{{- if not $taps -}}
#!/bin/sh
# No taps defined for {{ .chezmoi.os }} — nothing to do
exit 0
{{ else -}}
#!/bin/bash
# Add Homebrew taps with retry and verification
# Runs before package install (05 < 10)

set -euo pipefail

{{ template "script-log.sh" }}
{{ template "brew-preamble.sh" . }}

log_step "Adding Homebrew taps"

MAX_RETRIES=3
RETRY_DELAY=5

add_tap() {
  local tap="$1"
  local attempt=1

  while [ $attempt -le $MAX_RETRIES ]; do
    if brew tap "$tap" 2>/dev/null; then
      return 0
    fi
    log_warn "Tap '$tap' failed (attempt $attempt/$MAX_RETRIES), retrying in ${RETRY_DELAY}s..."
    sleep $RETRY_DELAY
    attempt=$((attempt + 1))
  done

  log_error "Failed to add tap '$tap' after $MAX_RETRIES attempts"
  exit 1
}

verify_tap() {
  local tap="$1"
  if ! brew tap-info "$tap" >/dev/null 2>&1; then
    log_error "Tap '$tap' is not available after adding"
    exit 1
  fi
}

{{ range $taps -}}
log_info "Tapping {{ . }}..."
add_tap {{ . | quote }}
verify_tap {{ . | quote }}
log_success "{{ . }}"
{{ end -}}

log_success "All taps verified"
{{ end -}}
{{ else -}}
{{ fail (printf "unsupported OS: %s" .chezmoi.os) }}
{{ end -}}
