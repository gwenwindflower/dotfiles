{{ if eq .chezmoi.os "darwin" "linux" -}}
#!/bin/bash
# Build bat theme cache so custom themes (Catppuccin) are available
# Needs to run after bat config + themes are deployed (files before scripts)

set -euo pipefail

{{ template "script-log.sh" }}
{{ template "brew-preamble.sh" . }}

log_step "Bat theme cache"

if command -v bat >/dev/null 2>&1; then
  log_info "Building bat cache..."
  bat cache --build
  log_success "Bat cache built"
else
  log_warn "bat not found, skipping cache build"
fi
{{ else -}}
{{ fail (printf "unsupported OS: %s" .chezmoi.os) }}
{{ end -}}
