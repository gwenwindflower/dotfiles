{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
# Add Fish shell to allowed shells and set as default (macOS)
# Runs once on first chezmoi apply

FISH_PATH="$(brew --prefix)/bin/fish"
{{ else if eq .chezmoi.os "linux" -}}
#!/bin/bash
# Add Fish shell to allowed shells and set as default (Linux)
# Runs once on first chezmoi apply

# Ensure brew is on PATH
if [ -x "/home/linuxbrew/.linuxbrew/bin/brew" ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

FISH_PATH="$(brew --prefix)/bin/fish"
{{ else -}}
{{ fail (printf "unsupported OS: %s" .chezmoi.os) }}
{{ end -}}

if ! grep -qF "$FISH_PATH" /etc/shells; then
  echo "$FISH_PATH" | sudo tee -a /etc/shells >/dev/null
  echo "[INFO] Added $FISH_PATH to /etc/shells"
fi

if [ "$SHELL" != "$FISH_PATH" ]; then
  chsh -s "$FISH_PATH"
  echo "[INFO] Changed default shell to Fish"
fi
