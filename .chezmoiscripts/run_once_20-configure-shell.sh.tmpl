{{ if eq .chezmoi.os "darwin" "linux" -}}
#!/bin/bash
# Add Fish shell to allowed shells and set as default
# Runs once on first chezmoi apply

set -euo pipefail

{{ template "script-log.sh" }}
{{ template "brew-preamble.sh" . }}

log_step "Configuring default shell"

FISH_PATH="$(brew --prefix)/bin/fish"

if [ ! -x "$FISH_PATH" ]; then
  log_error "Fish not found at $FISH_PATH"
  exit 1
fi

if ! grep -qF "$FISH_PATH" /etc/shells; then
  log_info "Adding $FISH_PATH to /etc/shells..."
  echo "$FISH_PATH" | sudo tee -a /etc/shells >/dev/null
  log_success "Added Fish to /etc/shells"
else
  log_info "Fish already in /etc/shells"
fi

if [ "$SHELL" != "$FISH_PATH" ]; then
  log_info "Changing default shell to Fish..."
{{- if eq .chezmoi.os "linux" }}
  # Linux: chsh uses PAM and prompts for password even with sudo privs,
  # so use sudo chsh which bypasses PAM authentication
  sudo chsh -s "$FISH_PATH" "$(whoami)"
{{- else }}
  chsh -s "$FISH_PATH"
{{- end }}
  log_success "Default shell changed to Fish"
else
  log_info "Fish is already the default shell"
fi
{{ else -}}
{{ fail (printf "unsupported OS: %s" .chezmoi.os) }}
{{ end -}}
