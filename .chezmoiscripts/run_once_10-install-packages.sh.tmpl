{{ if eq .chezmoi.os "darwin" "linux" -}}
#!/bin/bash
# Install Homebrew packages (formulae + casks on darwin, formulae only on linux)
# Taps are handled by run_once_05-add-taps.sh.tmpl

set -euo pipefail

{{ template "script-log.sh" }}
{{ template "brew-preamble.sh" . }}

log_step "Installing Homebrew packages"

{{- $taps := list -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $taps = .packages.darwin.homebrew.taps -}}
{{- else -}}
{{-   $taps = .packages.linux.homebrew.taps -}}
{{- end }}
{{ if $taps -}}
# Verify taps are available before installing packages that depend on them
{{ range $taps -}}
if ! brew tap-info {{ . | quote }} >/dev/null 2>&1; then
  log_error "Required tap {{ . | quote }} is missing — run_once_05 may have failed"
  exit 1
fi
{{ end -}}
log_info "All required taps present"
{{ end -}}

{{ if eq .chezmoi.os "darwin" -}}
log_info "Installing {{ len .packages.darwin.homebrew.formulae }} formulae and {{ len .packages.darwin.homebrew.casks }} casks..."
{{ else -}}
log_info "Installing {{ len .packages.linux.homebrew.formulae }} formulae..."
{{ end -}}

brew bundle --file=/dev/stdin <<EOF
{{ if eq .chezmoi.os "darwin" -}}
{{ range .packages.darwin.homebrew.formulae -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.homebrew.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ else -}}
{{ range .packages.linux.homebrew.formulae -}}
brew {{ . | quote }}
{{ end -}}
{{ end -}}
EOF

log_success "Package installation complete"
{{ else -}}
{{ fail (printf "unsupported OS: %s" .chezmoi.os) }}
{{ end -}}
