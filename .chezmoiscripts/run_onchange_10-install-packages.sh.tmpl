{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
# Install macOS Homebrew packages (taps, formulae, casks)
# Re-runs when packages.yaml changes (run_onchange_)

brew bundle --no-lock --file=/dev/stdin <<EOF
{{ range .packages.darwin.homebrew.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.homebrew.formulae -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.homebrew.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF
{{ else if eq .chezmoi.os "linux" -}}
#!/bin/bash
# Install Linux Homebrew packages (taps, formulae only — no casks)
# Re-runs when packages.yaml changes (run_onchange_)

# Ensure brew is on PATH for this script
if [ -x "/home/linuxbrew/.linuxbrew/bin/brew" ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

brew bundle --no-lock --file=/dev/stdin <<EOF
{{ range .packages.linux.homebrew.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.linux.homebrew.formulae -}}
brew {{ . | quote }}
{{ end -}}
EOF
{{ else -}}
{{ fail (printf "unsupported OS: %s" .chezmoi.os) }}
{{ end -}}
