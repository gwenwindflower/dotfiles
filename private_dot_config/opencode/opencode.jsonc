{
	"$schema": "https://opencode.ai/config.json",

	"model": "github-copilot/claude-opus-4.6",
	"small_model": "github-copilot/gpt-5.4-mini",
	"permission": {
		"bash": {
			"* --help *": "allow",
			"* --version": "allow",
			"bat *": "allow",
			"cat *": "allow",
			"chezmoi diff *": "allow",
			"chezmoi apply -n *": "allow",
			"chezmoi cat *": "allow",
			"chezmoi data *": "allow",
			"chezmoi managed *": "allow",
			"chezmoi doctor *": "allow",
			"echo *": "allow",
			"fd *": "allow",
			"find *": "allow",
			"git branch *": "allow",
			"git diff *": "allow",
			"git log *": "allow",
			"git show *": "allow",
			"git stash list": "allow",
			"git status *": "allow",
			"go build *": "allow",
			"go run main.go": "allow",
			"go test *": "allow",
			"go tool pprof *": "allow",
			"go vet *": "allow",
			"gofmt *": "allow",
			"gopls *": "allow",
			"grep *": "allow",
			"ls *": "allow",
			"lsd *": "allow",
			"make *": "allow",
			"notesmd-cli search *": "allow",
			"notesmd-cli search-content *": "allow",
			"npm run build": "allow",
			"npm run dev": "allow",
			"npm run lint": "allow",
			"npm run test *": "allow",
			"npx tsc *": "allow",
			"pnpm run build": "allow",
			"pnpm run dev": "allow",
			"pnpm run lint": "allow",
			"pnpm run test *": "allow",
			"printf *": "allow",
			"pwd": "allow",
			"rg *": "allow",
			"skillutil *": "allow",
			"task *": "allow",
			"tree *": "allow",
			"uname *": "allow",
			"wc *": "allow",
			"which *": "allow",
			"yuzudraw-cli *": "allow",
			"wt switch *": "allow",

			"rip": "ask",
			"git commit *": "ask",
			"wt merge *": "ask",

			"rm -rf *": "deny",
			"sudo rm *": "deny",
			"chmod -R 777 *": "deny",
			"dd *": "deny",
			"mkfs *": "deny",
			"git push *": "deny",
			"kubectl delete *": "deny",
			"kubectl apply * --namespace=prod*": "deny",
			"terraform destroy *": "deny",
			"op *": "deny"
		},
		"skill": "allow",
		"read": {
			".env": "deny",
			".env.*": "deny",
			"*.env": "deny",
			"**/.env": "deny",
			"**/.env.*": "deny",
			"**/*.env": "deny",
			"~/.ssh/**": "deny",
			"~/.aws/**": "deny",
			"~/.gnupg/**": "deny",
			"~/.config/gcloud/**": "deny",
			"**/secrets/**": "deny",
			"**/credentials/**": "deny",
			"*.pem": "deny",
			"*.key": "deny",
			"*.p12": "deny",
			"*.pfx": "deny",
			"id_rsa": "deny",
			"id_ed25519": "deny"
		},
		"edit": {
			".env": "deny",
			".env.*": "deny",
			"*.env": "deny",
			"~/.ssh/**": "deny",
			"~/.aws/**": "deny",
			"~/.gnupg/**": "deny",
			"~/.config/gcloud/**": "deny",
			"**/secrets/**": "deny",
			"**/credentials/**": "deny",
			"*.pem": "deny",
			"*.key": "deny",
			"*.p12": "deny",
			"*.pfx": "deny",
			"id_rsa": "deny",
			"id_ed25519": "deny"
		}
	},
	"instructions": [
		// primary source of truth
		// for multi-agent rules
		"~/.agents/rules/*.md",
		".agents/docs/**/*.md",
		".agents/rules/**/*.md",
		// project-local claude rules and docs
		// should be used, but migrated to .agents
		// if possible
		".claude/docs/**/*.md",
		".claude/rules/**/*.md"
	],
	"snapshot": true,
	// Updated via Homebrew
	"autoupdate": false
}
