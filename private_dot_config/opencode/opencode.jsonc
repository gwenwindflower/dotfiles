{
	"$schema": "https://opencode.ai/config.json",

	"model": "github-copilot/claude-opus-4.6",
	"small_model": "github-copilot/gpt-5.4-mini",
	"permission": {
		"bash": {
			"*": "ask",
			"* --help *": "allow",
			"* --version": "allow",
			"bat *": "allow",
			"blacksmith *": "allow",
			"bun build *": "allow",
			"bun dev *": "allow",
			"bun run build *": "allow",
			"bun run dev *": "allow",
			"bun run lint *": "allow",
			"bun run test *": "allow",
			"bun test *": "allow",
			"bun x tsc *": "allow",
			"bunx ctx7 docs *": "allow",
			"bunx ctx7 library *": "allow",
			"bunx skills list -g *": "allow",
			"bunx skills upgrade -g *": "allow",
			"bunx skills list *": "allow",
			"bunx skills upgrade *": "allow",
			"cargo check *": "allow",
			"cargo clippy *": "allow",
			"cargo test *": "allow",
			"cat *": "allow",
			"chezmoi diff *": "allow",
			"chezmoi apply -n *": "allow",
			"chezmoi cat *": "allow",
			"chezmoi data *": "allow",
			"chezmoi managed *": "allow",
			"chezmoi doctor *": "allow",
			"deno check *": "allow",
			"deno fmt *": "allow",
			"deno info *": "allow",
			"deno lint *": "allow",
			"deno task *": "allow",
			"deno test *": "allow",
			"diff *": "allow",
			"echo *": "allow",
			"fd *": "allow",
			"file *": "allow",
			"find *": "allow",
			"git blame *": "allow",
			"git branch *": "allow",
			"git diff *": "allow",
			"git log *": "allow",
			"git remote -v": "allow",
			"git rev-parse *": "allow",
			"git show *": "allow",
			"git stash list": "allow",
			"git status *": "allow",
			"git tag --list *": "allow",
			"go build *": "allow",
			"go run main.go": "allow",
			"go test *": "allow",
			"go tool pprof *": "allow",
			"go vet *": "allow",
			"gofmt *": "allow",
			"gopls *": "allow",
			"grep *": "allow",
			"jq *": "allow",
			"ls *": "allow",
			"lsd *": "allow",
			"make *": "allow",
			"mise current *": "allow",
			"mise ls *": "allow",
			"notesmd-cli search *": "allow",
			"notesmd-cli search-content *": "allow",
			"npm build *": "allow",
			"npm dev *": "allow",
			"npm fix *": "allow",
			"npm format *": "allow",
			"npm fix-format *": "allow",
			"npm lint *": "allow",
			"npm ls *": "allow",
			"npm run build *": "allow",
			"npm run dev *": "allow",
			"npm run lint *": "allow",
			"npm run test *": "allow",
			"npm typecheck *": "allow",
			"npx tsc *": "allow",
			"pnpm build *": "allow",
			"pnpm dev *": "allow",
			"pnpm fix *": "allow",
			"pnpm fix-format *": "allow",
			"pnpm format *": "allow",
			"pnpm lint *": "allow",
			"pnpm ls *": "allow",
			"pnpm run build *": "allow",
			"pnpm run dev *": "allow",
			"pnpm run lint *": "allow",
			"pnpm run test *": "allow",
			"pnpm typecheck *": "allow",
			"pnpx tsc *": "allow",
			"printf *": "allow",
			"procs *": "allow",
			"pwd": "allow",
			"rg *": "allow",
			"rei *": "allow",
			"sd -p *": "allow",
			"task *": "allow",
			"tree *": "allow",
			"uname *": "allow",
			"uv python upgrade *": "allow",
			"uv run pytest *": "allow",
			"uv sync *": "allow",
			"uv tool list *": "allow",
			"uv tool upgrade *": "allow",
			"uv venv *": "allow",
			"wc *": "allow",
			"which *": "allow",
			"wt list *": "allow",
			"wt status *": "allow",
			"wt switch *": "allow",
			"yq *": "allow",
			"yuzudraw-cli *": "allow",

			"rm -rf *": "deny",
			"rm -rf /*": "deny",
			"sudo rm *": "deny",
			"chmod -R 777 *": "deny",
			"dd *": "deny",
			"mkfs *": "deny",
			"git push --force *": "deny",
			"git push -f *": "deny",
			"kubectl delete *": "deny",
			"kubectl apply * --namespace=prod*": "deny",
			"terraform destroy *": "deny",
			"op *": "deny"
		},
		"skill": "allow",
		"read": {
			".env": "deny",
			".env.*": "deny",
			"*.env": "deny",
			"**/.env": "deny",
			"**/.env.*": "deny",
			"**/*.env": "deny",
			"~/.ssh/**": "deny",
			"~/.aws/**": "deny",
			"~/.gnupg/**": "deny",
			"~/.config/gcloud/**": "deny",
			"**/secrets/**": "deny",
			"**/credentials/**": "deny",
			"*.pem": "deny",
			"*.key": "deny",
			"*.p12": "deny",
			"*.pfx": "deny",
			"id_rsa": "deny",
			"id_ed25519": "deny"
		},
		"edit": {
			".env": "deny",
			".env.*": "deny",
			"*.env": "deny",
			"~/.ssh/**": "deny",
			"~/.aws/**": "deny",
			"~/.gnupg/**": "deny",
			"~/.config/gcloud/**": "deny",
			"**/secrets/**": "deny",
			"**/credentials/**": "deny",
			"*.pem": "deny",
			"*.key": "deny",
			"*.p12": "deny",
			"*.pfx": "deny",
			"id_rsa": "deny",
			"id_ed25519": "deny"
		}
	},
	"instructions": [
		// primary source of truth
		// for multi-agent rules
		"~/.agents/rules/*.md",
		".agents/docs/**/*.md",
		".agents/rules/**/*.md",
		// project-local claude rules and docs
		// should be used, but migrated to .agents
		// if possible
		".claude/docs/**/*.md",
		".claude/rules/**/*.md"
	],
	"snapshot": true,
	// Updated via Homebrew
	"autoupdate": false
}
