# Fish shell configuration — assembled by chezmoi from .chezmoitemplates/fish/
# Do not edit the deployed ~/.config/fish/config.fish directly.
# Edit fragments in ~/.local/share/chezmoi/.chezmoitemplates/fish/ instead.

# =============================================================================
# Environment (always loaded)
# =============================================================================

# Homebrew (dynamic at chezmoi apply)
{{ output (joinPath .brewPrefix "bin/brew") "shellenv" "fish" -}}
set -gx HOMEBREW_NO_ENV_HINTS 1

{{ template "fish/00-core-env.fish" . }}

{{- if eq .chezmoi.os "darwin" }}
# SSH (macOS only — on Linux, ssh agent forwarding handles this)
set -gx SSH_AUTH_SOCK "$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

{{ template "fish/04-mac-tools.fish" . }}
{{- end }}

# Dotfiles home
set -gx DOTFILES '{{ .chezmoi.sourceDir }}'

{{ template "fish/01-editor.fish" . }}
{{ template "fish/02-git.fish" . }}
{{ template "fish/03-ai.fish" . }}
{{ template "fish/10-rust.fish" . }}
{{ template "fish/11-typescript.fish" . }}
{{ template "fish/12-go.fish" . }}
{{ template "fish/13-python.fish" . }}
{{ template "fish/14-ruby.fish" . }}

# We re-add Homebrew with -m here
# which pushes it to the front of PATH
# so that it still takes precedence over all
# the language and tool-specific paths set above
fish_add_path -m $HOMEBREW_PREFIX/bin

# =============================================================================
# Interactive-only
# =============================================================================
if status is-interactive

{{ template "fish/20-theme.fish" . }}
{{ template "fish/22-abbreviations.fish" . }}
{{ template "fish/23-bindings.fish" . }}
{{- if eq .chezmoi.os "darwin" }}
{{ template "fish/23-bindings_macos.fish" . }}
{{- end }}
# zoxide init
{{ output (joinPath .brewPrefix "bin/zoxide") "init" "fish" }}

# starship init
{{ output (joinPath .brewPrefix "bin/starship") "init" "fish" }}

{{ template "fish/24-tools.fish" . }}

set -gx LS_COLORS "{{ output (joinPath .brewPrefix "bin/vivid") "generate" "catppuccin-frappe" }}"

end # status is-interactive
