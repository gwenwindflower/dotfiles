{
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@std/cli": "jsr:@std/cli@^1",
    "@std/fmt/colors": "jsr:@std/fmt@^1/colors",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/path": "jsr:@std/path@^1",
    "text-to-svg": "npm:text-to-svg@^3.1.5"
  },
  "nodeModulesDir": "auto",
  "tasks": {
    "fix-tables": "deno run --allow-read --allow-write fix-md-tables.ts",
    "check-tables": "deno run --allow-read fix-md-tables.ts --check",
    "preview-tables": "deno run --allow-read fix-md-tables.ts --dry-run",
    "logo": "deno run --allow-read --allow-write --allow-env generate-logo.ts",
    "test": "deno run --allow-read --allow-run=deno scripts/test.ts",
    "test:tables": "deno test --allow-read fix-md-tables_test.ts",
    "test:logo": "deno test --allow-read --allow-env generate-logo_test.ts"
  }
}
